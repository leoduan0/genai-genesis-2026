generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum DimensionLevel {
  SPECTRUM
  CONDITION
}

enum SourceQuality {
  META_ANALYSIS
  LARGE_STUDY
  SMALL_STUDY
  DERIVED
  ESTIMATED
}

enum PopulationType {
  GENERAL
  CLINICAL
  COLLEGE
  PRIMARY_CARE
}

enum InstrumentTier {
  BROAD_SCREENING
  TARGETED
}

enum DerivationMethod {
  DIRECT
  CHAINED
  ESTIMATED
}

enum OverlapStrength {
  HIGH
  MODERATE
  LOW
}

enum ContentTag {
  SLEEP
  APPETITE
  WEIGHT
  FATIGUE
  CONCENTRATION
  PSYCHOMOTOR
  ANHEDONIA
  DEPRESSED_MOOD
  WORTHLESSNESS
  SUICIDALITY
  WORRY
  RESTLESSNESS
  IRRITABILITY
  MUSCLE_TENSION
  PANIC
  AVOIDANCE
  HYPERAROUSAL
  INTRUSIONS
  NUMBING
  DISSOCIATION
  FLASHBACKS
  SOMATIC_PAIN
  SOMATIC_GI
  SOMATIC_CARDIO
  SOMATIC_NEURO
  ALCOHOL_USE
  DRUG_USE
  GAMBLING
  IMPULSIVITY
  AGGRESSION
  RULE_BREAKING
  GRANDIOSITY
  MANIPULATIVENESS
  CALLOUSNESS
  HALLUCINATIONS
  DELUSIONS
  PARANOIA
  DISORGANIZED_THOUGHT
  MANIA
  HYPOMANIA
  SOCIAL_WITHDRAWAL
  EMOTIONAL_DETACHMENT
  DEPERSONALIZATION
  DEREALIZATION
  OBSESSIONS
  COMPULSIONS
  HOARDING
  BODY_IMAGE
  RESTRICTED_EATING
  BINGE_EATING
  TICS
  PERFECTIONISM
  RIGIDITY
  SENSORY_SENSITIVITY
  INATTENTION
  HYPERACTIVITY
  MAGICAL_THINKING
  ECCENTRIC_BEHAVIOR
  HEALTH_ANXIETY
  PURGING
  RISK_TAKING
  TALKATIVENESS
  EMOTIONAL_LABILITY
  HOSTILITY
  IRRESPONSIBILITY
  WITHDRAWAL
}

// ─── Psychometric Reference Data (Static) ────────────────────────────────────

model Dimension {
  id          String         @id @default(cuid())
  name        String
  shortCode   String         @unique
  level       DimensionLevel
  parentId    String?
  description String?
  sortOrder   Int

  parent   Dimension?  @relation("DimensionHierarchy", fields: [parentId], references: [id])
  children Dimension[] @relation("DimensionHierarchy")

  correlationsA             DimensionCorrelation[]     @relation("CorrelationDimA")
  correlationsB             DimensionCorrelation[]     @relation("CorrelationDimB")
  conditionLoadings         ConditionSpectrumLoading[] @relation("LoadingCondition")
  spectrumLoadings          ConditionSpectrumLoading[] @relation("LoadingSpectrum")
  baseRates                 BaseRate[]
  clinicalThresholds        ClinicalThreshold[]
  itemLoadings              ItemLoading[]
  sessionDiagnoses          SessionDiagnosis[]

  @@index([level])
}

model DimensionCorrelation {
  id            String        @id @default(cuid())
  dimensionAId  String
  dimensionBId  String
  correlation   Float
  sourceQuality SourceQuality
  sources       Json
  notes         String?

  dimensionA Dimension @relation("CorrelationDimA", fields: [dimensionAId], references: [id])
  dimensionB Dimension @relation("CorrelationDimB", fields: [dimensionBId], references: [id])

  @@unique([dimensionAId, dimensionBId])
}

model ConditionSpectrumLoading {
  id            String        @id @default(cuid())
  conditionId   String
  spectrumId    String
  loading       Float
  isPrimary     Boolean
  sourceQuality SourceQuality
  sources       Json
  notes         String?

  condition Dimension @relation("LoadingCondition", fields: [conditionId], references: [id])
  spectrum  Dimension @relation("LoadingSpectrum", fields: [spectrumId], references: [id])

  @@unique([conditionId, spectrumId])
}

model BaseRate {
  id             String         @id @default(cuid())
  dimensionId    String
  populationType PopulationType
  prevalence     Float
  liabilityMean  Float
  sourceQuality  SourceQuality
  sources        Json
  notes          String?

  dimension Dimension @relation(fields: [dimensionId], references: [id])

  @@unique([dimensionId, populationType])
}

model Instrument {
  id                  String         @id @default(cuid())
  name                String         @unique
  fullName            String
  tier                InstrumentTier
  itemCount           Int
  responseScale       Json
  scaleReliabilityIcc Float?
  retestIntervalDays  Int?
  citation            String

  items Item[]
}

model Item {
  id                    String        @id @default(cuid())
  instrumentId          String
  itemNumber            Int
  text                  String
  responseMin           Int
  responseMax           Int
  responseLabels        Json
  isReverseCoded        Boolean       @default(false)
  testRetestR           Float?
  noiseVariance         Float         @default(0.5)
  noiseInflationFactor  Float         @default(1.5)
  normativeMean         Float?        // Population mean response (for z-score normalization)
  normativeSD           Float?        // Population SD of response (for z-score normalization)
  normativeResponseDist Float[]       @default([]) // Proportion choosing each response category [P(min), P(min+1), ..., P(max)] for probit normalization
  sourceQuality         SourceQuality @default(ESTIMATED)
  tags                  ContentTag[]

  instrument       Instrument        @relation(fields: [instrumentId], references: [id])
  loadings         ItemLoading[]
  overlapsA        ItemOverlap[]     @relation("OverlapItemA")
  overlapsB        ItemOverlap[]     @relation("OverlapItemB")
  sessionResponses SessionResponse[]

  @@unique([instrumentId, itemNumber])
}

model ItemLoading {
  id                          String           @id @default(cuid())
  itemId                      String
  dimensionId                 String
  loading                     Float
  isPrimary                   Boolean
  derivationMethod            DerivationMethod
  withinInstrumentLoading     Float?
  instrumentToDimensionLoading Float?
  sourceQuality               SourceQuality
  sources                     Json
  notes                       String?

  item      Item      @relation(fields: [itemId], references: [id])
  dimension Dimension @relation(fields: [dimensionId], references: [id])

  @@unique([itemId, dimensionId])
}

model ItemOverlap {
  id                        String          @id @default(cuid())
  itemAId                   String
  itemBId                   String
  overlapStrength           OverlapStrength
  sharedTags                ContentTag[]
  description               String
  noiseInflationMultiplier  Float

  itemA Item @relation("OverlapItemA", fields: [itemAId], references: [id])
  itemB Item @relation("OverlapItemB", fields: [itemBId], references: [id])

  @@unique([itemAId, itemBId])
}

model ClinicalThreshold {
  id                 String  @id @default(cuid())
  dimensionId        String
  thresholdLiability Float
  sensitivity        Float
  specificity        Float
  sourceInstrument   String?
  sourceCutoff       String?
  sources            Json
  notes              String?

  dimension Dimension @relation(fields: [dimensionId], references: [id])
}


// ─── Screening Session Data (Dynamic) ─────────────────────────────────────

enum ScreeningStage {
  INTAKE
  BROAD_SCREENING
  TARGETED
  COMPLETE
}

enum TerminationReason {
  CONFIDENCE_MET
  NO_INFO_GAIN
  MAX_ITEMS
  USER_STOPPED
}

model ScreeningSession {
  id                          String              @id @default(cuid())
  patientId                   String
  populationType              PopulationType

  stage                       ScreeningStage      @default(INTAKE)

  // Stage 1: spectrum-level posteriors
  spectrumPriorMean           Float[]
  spectrumPriorCovariance     Json                // 2D array (N×N)
  spectrumPosteriorMean       Float[]             @default([])
  spectrumPosteriorCovariance Json?               // 2D array (N×N), null until first item

  // Stage 2: condition-level posteriors (diagonal — independent given spectrum)
  conditionPriorMean          Float[]             @default([])
  conditionPosteriorMean      Float[]             @default([])
  conditionPosteriorVariances Float[]             @default([])
  conditionDimensionOrder     String[]            @default([])

  // Flagged spectra (persisted from stage transition)
  flaggedSpectra              String[]            @default([])

  // Metadata
  initialTrace                Float?              // tr(Σ₀), set on first respond call
  itemsAdministered           Int                 @default(0)
  stageTransitionAt           DateTime?
  terminated                  Boolean             @default(false)
  terminationReason           TerminationReason?
  startedAt                   DateTime            @default(now())
  completedAt                 DateTime?

  patient                     Patient             @relation(fields: [patientId], references: [id])
  responses                   SessionResponse[]
  diagnoses                   SessionDiagnosis[]

  @@index([patientId])
  @@map("screening_session")
}

model SessionResponse {
  id                    String           @id @default(cuid())
  sessionId             String
  itemId                String
  responseRaw           Int
  responseNormalized    Float
  administrationOrder   Int
  stage                 ScreeningStage
  kalmanGain            Float[]
  posteriorMeanAfter    Float[]
  posteriorDiagAfter    Float[]
  runtimeNoiseVariance  Float
  infoGain              Float
  respondedAt           DateTime         @default(now())

  session               ScreeningSession @relation(fields: [sessionId], references: [id])
  item                  Item             @relation(fields: [itemId], references: [id])

  @@index([sessionId, administrationOrder])
  @@map("session_response")
}

model SessionDiagnosis {
  id            String           @id @default(cuid())
  sessionId     String
  dimensionId   String
  liability     Float
  uncertainty   Float
  threshold     Float
  probability   Float
  flagged       Boolean

  session       ScreeningSession @relation(fields: [sessionId], references: [id])
  dimension     Dimension        @relation(fields: [dimensionId], references: [id])

  @@unique([sessionId, dimensionId])
  @@map("session_diagnosis")
}

// ─── User & Auth ──────────────────────────────────────────────────────────

enum ROLES {
  DOCTOR
  PATIENT
}

model User {
  id        String @id
  email     String
  firstName String @map("first_name")
  lastName  String @map("last_name")
  role      ROLES

  doctor  Doctor?
  patient Patient?

  createdAt DateTime @default(now()) @map("created_at")

  @@map("user")
}

model Doctor {
  id       String    @id @default(uuid())
  patients Patient[]

  user   User   @relation(fields: [userId], references: [id])
  userId String @unique @map("user_id")

  @@map("doctor")
}

enum GENDER {
  MALE
  FEMALE
  OTHER
}

model Patient {
  id String @id @default(uuid())

  age             Int
  gender          GENDER
  doctorId        String?          @map("doctor_id")
  doctor          Doctor?          @relation(fields: [doctorId], references: [id])
  chatSessions       ChatSession[]
  therapySessions    TherapySession[]
  screeningSessions  ScreeningSession[]

  user   User   @relation(fields: [userId], references: [id])
  userId String @unique @map("user_id")

  @@map("patient")
}

model ChatSession {
  id        String        @id @default(uuid())
  patientId String        @map("patient_id")
  doctorId  String?       @map("doctor_id")
  status    String        @default("open")
  createdAt DateTime      @default(now()) @map("created_at")
  endedAt   DateTime?     @map("ended_at")
  patient   Patient       @relation(fields: [patientId], references: [id])
  messages  ChatMessage[]

  @@map("chat_session")
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String      @map("session_id")
  role      String
  content   String
  createdAt DateTime    @default(now()) @map("created_at")
  session   ChatSession @relation(fields: [sessionId], references: [id])

  @@map("chat_message")
}

model TherapySession {
  id         String           @id @default(uuid())
  patientId  String           @map("patient_id")
  doctorId   String?          @map("doctor_id")
  title      String?
  transcript String?
  summary    String?
  createdAt  DateTime         @default(now()) @map("created_at")
  patient    Patient          @relation(fields: [patientId], references: [id])
  messages   TherapyMessage[]

  @@map("therapy_session")
}

model TherapyMessage {
  id        String         @id @default(uuid())
  sessionId String         @map("session_id")
  role      String
  content   String
  createdAt DateTime       @default(now()) @map("created_at")
  session   TherapySession @relation(fields: [sessionId], references: [id])

  @@map("therapy_message")
}
